# ===========================================
# ailine 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# ===========================================

# ----- データベース（必須）-----
# Turso: https://turso.tech
# 取得: turso db show <db名> --url
#       turso db tokens create <db名>
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ----- 認証（必須）-----
# 生成: npx auth secret
AUTH_SECRET=your-auth-secret-min-32-chars

# 本番: https://your-app.vercel.app
# 開発: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ----- 初回システム管理者（必須）-----
# OAuthログイン時にこのメールのユーザーにシステム管理者ロールを付与
INITIAL_ADMIN_EMAIL=admin@example.com

# メール・パスワード認証を使う場合（任意）
INITIAL_ADMIN_PASSWORD=

# ----- OAuth（推奨）-----
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ----- APIキー暗号化（任意）-----
# 未設定時は AUTH_SECRET を使用
# ENCRYPTION_KEY=

# ----- Inngest（本番必須）-----
# https://app.inngest.com でアプリ登録後
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ----- Stripe（課金を有効にする場合のみ）-----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_PRO=
# ユーザー課金用（LINEユーザー向けプランのStripe Price ID）
STRIPE_PRICE_ID_USER_STANDARD=
STRIPE_PRICE_ID_USER_PRO=
